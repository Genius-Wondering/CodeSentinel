# Required
OPENAI_API_KEY=your_openai_api_key_here

# Optional - defaults shown
OPENAI_MODEL=gpt-4o-mini
CHROMA_PERSIST_DIR=./data/chroma
RETRIEVER_TOP_K=5
CHUNK_SIZE_LINES=50

# Persistent metadata store (document/repo versions + query logs)
# Swap to mysql+pymysql://user:pass@host:3306/codesentinel or
# postgresql+psycopg2://user:pass@host:5432/codesentinel for production.
DATABASE_URL=sqlite:///./data/codesentinel.db

# Intent-adaptive retrieval (BM25/vector weighting + fetch-pool size by
# classified query intent). Set to false to use fixed global weights.
INTENT_ROUTING_ENABLED=true
